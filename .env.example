# ─────────────────────────────────────────
# SMTP Configuration
# ─────────────────────────────────────────

# SMTP Server (Gmail, Outlook, dll)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# SMTP Credentials
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Sender Email (optional, default = SMTP_USER)
SMTP_FROM=your-email@gmail.com

# ─────────────────────────────────────────
# Search API Keys (Optional but Recommended)
# ─────────────────────────────────────────

# SerpAPI - Google Search API (Primary)
# Get your key: https://serpapi.com/
# Free tier: 100 searches/month
SERPAPI_KEY=your-serpapi-key-here

# Serper.dev - Google Search API (Fallback)
# Get your key: https://serper.dev/
# Free tier: 2,500 searches/month
SERPER_API_KEY=your-serper-api-key-here

# ─────────────────────────────────────────
# Notes:
# ─────────────────────────────────────────
# 
# Gmail:
# - SMTP_HOST: smtp.gmail.com
# - SMTP_PORT: 587
# - SMTP_PASS: Gunakan App Password, bukan password biasa
#   Cara buat: https://myaccount.google.com/apppasswords
#
# Outlook/Hotmail:
# - SMTP_HOST: smtp-mail.outlook.com
# - SMTP_PORT: 587
# - SMTP_USER: your-email@outlook.com
#
# Yahoo:
# - SMTP_HOST: smtp.mail.yahoo.com
# - SMTP_PORT: 587
#
# Custom SMTP:
# - Sesuaikan dengan provider email kamu
#
# Search APIs:
# - Jika tidak ada API key, akan fallback ke HTML scraping
# - HTML scraping bisa kena CAPTCHA/block
# - Recommended: gunakan minimal 1 API key
